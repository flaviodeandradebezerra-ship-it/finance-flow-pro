{
  "version": 2,
  "routes": [
    {
      "src": "/api/.*",
      "dest": "api/index.py"
    },
    {
      "src": "/assets/.*",
      "dest": "/public/$1"
    },
    {
      "src": "/.*\\.(?:js|css|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot)$",
      "dest": "/public/$1"
    },
    {
      "src": "/.*",
      "dest": "/public/index.html"
    }
  ]
}
